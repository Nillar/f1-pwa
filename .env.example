# PostgreSQL connection string (get from Neon dashboard or your DB provider)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# VAPID keys for Web Push — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:you@example.com"

# Resend API key for sending magic link + reminder emails — from resend.com dashboard
RESEND_API_KEY=""

# Your deployed app URL (used in magic link emails and email templates)
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Secret token Vercel sends to the cron route — generate with: openssl rand -base64 32
CRON_SECRET=""
