# PostgreSQL connection string (get from Neon dashboard or your DB provider)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# VAPID keys for Web Push — generate with: npx web-push generate-vapid-keys
# Public key is exposed to the browser (used when subscribing)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# Private key stays server-side (used when sending push notifications)
VAPID_PRIVATE_KEY=""
# Contact email sent with push requests (required by VAPID spec)
VAPID_EMAIL="mailto:you@example.com"

# Secret token Vercel sends as Bearer in Authorization header to the cron route
# Generate with: openssl rand -base64 32  (or any long random string)
CRON_SECRET=""
